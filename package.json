{
  "name": "basileian-reader",
  "version": "2.0.0",
  "description": "Basileian Canon chronological harmony reader with NET Bible text and non-canonical sources",
  "private": true,
  "type": "module",
  "scripts": {
    "fetch-nonbiblical": "node scripts/fetch-nonbiblical.js",
    "build-canon": "node scripts/build-data.js",
    "build": "node scripts/fetch-nonbiblical.js && node scripts/build-data.js",
    "fetch-translations": "node scripts/fetch-translations.js",
    "fetch-commentary": "node scripts/fetch-commentary.js",
    "ingest-wh": "node ingest-wh.js",
    "build-lexicons": "node scripts/build-lexicons.js",
    "build:ot-concordance": "node scripts/fetch-ot-concordance.js",
    "setup-data": "npm run fetch-translations && npm run ingest-wh && npm run build-lexicons && npm run fetch-commentary"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "strongs": "^1.0.2"
  }
}
